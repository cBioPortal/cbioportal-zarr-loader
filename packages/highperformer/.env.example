# Base URL path for deployment (e.g. /cbioportal-zarr-loader/ for GitHub Pages)
VITE_BASE_URL=/

# Default dataset URL to load
VITE_DEFAULT_URL=

# Enable/disable deck.gl stats widget (default: true)
VITE_ENABLE_STATS_WIDGET=true

# Enable/disable query profiler bar and /profile route (default: true)
VITE_ENABLE_PROFILER=true
